{
    "include": ["start_web.py","src/**/*.py", "tests/**/*.py"],
    "exclude": ["**/node_modules/**", "**/__pycache__/**", "**/.*", ".venv.3.13"],
   
    "extraPaths": [
        "./src"
    ],
    "executionEnvironments": [
        {
            "root": "src"
        }
    ],
    "typeCheckingMode": "strict",
    "pythonVersion": "3.13",
    "pythonPlatform": "All"
}